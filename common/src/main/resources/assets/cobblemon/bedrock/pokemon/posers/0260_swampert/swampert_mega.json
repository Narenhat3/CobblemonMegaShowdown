        }
      ],
      "transformTicks": 5
    },
    "run": {
      "poseTypes": ["WALK", "SWIM"],
      "isTouchingWater": false,
      "condition": "!q.in_air && q.is_sprinting",
      "animations": [
        "q.bedrock('swampert_mega', 'ground_run')",
