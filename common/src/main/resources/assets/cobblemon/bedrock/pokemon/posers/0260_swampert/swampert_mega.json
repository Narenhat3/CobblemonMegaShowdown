    "surface-idle": {
      "poseTypes": ["STAND", "FLOAT"],
      "condition": "!q.is_ridden",
      "isTouchingWater": true,
      "isUnderWater": false,
      "animations": [
        "q.bedrock('swampert_mega', 'water_idle')",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('swampert_mega', 'ride_surface_water')"
        }
      ],
      "quirks": ["q.bedrock_quirk('swampert_mega', 'blink')"]
    },
    "surface-swim": {
      "poseTypes": ["WALK", "SWIM"],
      "condition": "!q.is_ridden",
      "isTouchingWater": true,
