      "poseTypes": ["STAND", "WALK"],
      "condition": "q.in_air && q.is_ridden",
      "animations": ["q.bedrock('swampert_mega', 'ride_jump')"],
      "transformTicks": 2,
      "transformToTicks": 2
    },
    "water-jump": {
      "poseTypes": ["FLOAT", "SWIM"],
      "condition": "q.is_ridden",
      "isTouchingWater": false,
      "animations": ["q.bedrock('swampert_mega', 'water_swim')"]
    },

    "standing": {
      "poseTypes": ["STAND", "FLOAT", "NONE", "PORTRAIT", "PROFILE"],
      "isBattle": false,
      "isTouchingWater": false,
      "condition": "!q.in_air",
      "animations": ["q.bedrock('swampert_mega', 'ground_idle')"],
      "quirks": ["q.bedrock_quirk('swampert_mega', 'blink')"],
      "transformTicks": 5
    },
    "battle-standing": {
      "poseTypes": ["STAND"],
      "isTouchingWater": false,
      "isBattle": true,
      "animations": ["q.bedrock('swampert_mega', 'battle_idle')"],
      "quirks": ["q.bedrock_quirk('swampert_mega', 'blink')"],
      "transformTicks": 5
    },
    "walk": {
      "poseTypes": ["WALK", "SWIM"],
      "isTouchingWater": false,
      "condition": "!q.in_air && !q.is_sprinting",
      "animations": [
        "q.bedrock('swampert_mega', 'ground_walk')",
