      "quirks": ["q.bedrock_quirk('swampert_mega', 'blink')"]
    },
    "mount-surface-idle": {
      "poseTypes": ["FLOAT"],
      "condition": "q.is_ridden",
      "isTouchingWater": true,
      "isUnderWater": false,
      "animations": [
        "q.bedrock('swampert_mega', 'water_idle')",
        "q.bedrock('swampert_mega', 'ride_surface_water')"
      ],
      "quirks": ["q.bedrock_quirk('swampert_mega', 'blink')"]
