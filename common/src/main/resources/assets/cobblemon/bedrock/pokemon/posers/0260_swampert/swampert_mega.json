        {
          "condition": "q.is_ridden && q.has_entity && !q.in_air",
          "animation": "q.bedrock('swampert_mega', 'ride_water_swim')"
        }
      ],
      "transformTicks": 5
    },
    "float": {
      "poseTypes": ["FLOAT"],
      "isUnderWater": true,
      "animations": [
        "q.bedrock('swampert_mega', 'water_idle')",
